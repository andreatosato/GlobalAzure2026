@namespace ReactiveOrders.Web.Components.Shared

<MudCard Elevation="3">
    <MudCardHeader>
        <CardHeaderAvatar>
            <MudAvatar Color="Color.Warning"><MudIcon Icon="@Icons.Material.Filled.EmojiEvents" /></MudAvatar>
        </CardHeaderAvatar>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Piatti più ordinati</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (Items.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Default">Nessun dato</MudText>
        }
        else
        {
            var max = Items.Max(i => i.TotalQuantity);
            foreach (var item in Items.Take(6))
            {
                <div class="mb-3">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.h6">@MenuCatalog.EmojiFor(item.ItemName)</MudText>
                        <MudText Typo="Typo.body2" Class="flex-grow-1" Style="font-weight:500;">@item.ItemName</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">x@(item.TotalQuantity)</MudChip>
                    </div>
                    <MudProgressLinear Color="Color.Primary" Value="@((double)item.TotalQuantity / max * 100)" Class="mt-1" />
                </div>
            }
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired] public List<PopularItem> Items { get; set; } = [];
}
