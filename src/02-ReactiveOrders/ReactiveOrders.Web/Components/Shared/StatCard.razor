@namespace ReactiveOrders.Web.Components.Shared

<MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center" Style="@($"border-left: 6px solid var(--mud-palette-{ColorVariable}); height:100%;")">
    <MudIcon Icon="@Icon" Color="@IconColor" Size="Size.Large" />
    <MudText Typo="Typo.h3" Class="mt-2" Style="font-weight:700;">@Value</MudText>
    <MudText Typo="Typo.body2" Color="Color.Default" Class="mud-text-secondary">@Label</MudText>
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Value { get; set; } = "0";
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info;
    [Parameter] public Color IconColor { get; set; } = Color.Primary;

    private string ColorVariable => IconColor switch
    {
        Color.Primary => "primary",
        Color.Secondary => "secondary",
        Color.Tertiary => "tertiary",
        Color.Success => "success",
        Color.Warning => "warning",
        Color.Error => "error",
        Color.Info => "info",
        _ => "primary"
    };
}
