@page "/orders"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.SignalR.Client
@using System.Net.Http.Json
@implements IAsyncDisposable
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject IDialogService DialogService

<PageTitle>ReactiveOrders — Ordini Live</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight:700;">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" /> Dashboard ordini
</MudText>

<StatsPanel Stats="_stats" />

<MudGrid Spacing="3" Class="mt-3">
    <MudItem xs="12" md="5" lg="4">
        <NewOrderForm OnOrderPlaced="LoadDataAsync" />
    </MudItem>
    <MudItem xs="12" md="7" lg="8">
        <OrdersTable Orders="_orders" OnRowClick="ShowDetails" />
    </MudItem>
    <MudItem xs="12" md="6">
        <PopularItemsPanel Items="_popularItems" />
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard Elevation="3" Class="h-100">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Tertiary"><MudIcon Icon="@Icons.Material.Filled.Bolt" /></MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Live stream</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Eventi dal SignalR hub</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent Style="max-height:260px; overflow-y:auto;">
                @if (_events.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">In attesa di eventi...</MudText>
                }
                else
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start">
                        @foreach (var ev in _events.Take(15))
                        {
                            <MudTimelineItem Color="@EventColor(ev.Type)" Size="Size.Small">
                                <ItemContent>
                                    <MudText Typo="Typo.body2"><b>@ev.Type</b> · @ev.OrderId.ToString()[..8]</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Default">@ev.At.ToLocalTime().ToString("HH:mm:ss")</MudText>
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private HubConnection? _hubConnection;
    private List<OrderView> _orders = [];
    private StatsView _stats = new();
    private List<PopularItem> _popularItems = [];
    private readonly List<LiveEvent> _events = new();

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/orderhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string, Guid>("OrderUpdate", async (eventType, orderId) =>
        {
            _events.Insert(0, new LiveEvent(eventType, orderId, DateTime.UtcNow));
            if (_events.Count > 50) _events.RemoveRange(50, _events.Count - 50);
            await LoadDataAsync();
        });

        await _hubConnection.StartAsync();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var readClient = HttpClientFactory.CreateClient("ReadApi");
            _orders = await readClient.GetFromJsonAsync<List<OrderView>>("/api/orders") ?? [];
            _stats = await readClient.GetFromJsonAsync<StatsView>("/api/stats") ?? new();
            _popularItems = await readClient.GetFromJsonAsync<List<PopularItem>>("/api/popular-items") ?? [];
            await InvokeAsync(StateHasChanged);
        }
        catch { /* ignore transient */ }
    }

    private async Task ShowDetails(OrderView order)
    {
        var parameters = new DialogParameters { [nameof(OrderDetailsDialog.OrderId)] = order.OrderId };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<OrderDetailsDialog>("Dettagli ordine", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false }) await LoadDataAsync();
    }

    private static Color EventColor(string type) => type switch
    {
        "OrderPlaced"    => Color.Warning,
        "OrderConfirmed" => Color.Success,
        "OrderRejected"  => Color.Error,
        "OrderCancelled" => Color.Default,
        _ => Color.Info
    };

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null) await _hubConnection.DisposeAsync();
    }

    private record LiveEvent(string Type, Guid OrderId, DateTime At);
}